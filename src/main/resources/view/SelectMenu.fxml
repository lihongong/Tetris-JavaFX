<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="mainLayout" alignment="CENTER" stylesheets="@select-menu.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label fx:id="titleLabel" alignment="TOP_CENTER" contentDisplay="TOP" minHeight="150.0" minWidth="680.0" prefHeight="150.0" prefWidth="680.0" stylesheets="@select-menu.css" text="Select Game Mode" />
      <HBox>
         <children>
            <VBox HBox.hgrow="ALWAYS" minWidth="300.0" maxWidth="1.7976931348623157E308" />
            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" prefHeight="200.0" spacing="20.0">
               <children>
                  <Button fx:id="relaxButton" focusTraversable="false" minHeight="100.0" minWidth="500.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRelaxButton" onMouseEntered="#handleRelaxButtonMouseEnter" onMouseExited="#handleRelaxButtonMouseExit" prefWidth="400.0" styleClass="left-aligned-button" stylesheets="@select-menu.css" text="Relax" />
                  <Button fx:id="sprintButton" focusTraversable="false" minHeight="100.0" minWidth="500.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSprintButton" onMouseEntered="#handleSprintButtonMouseEnter" onMouseExited="#handleSprintButtonMouseExit" prefHeight="100.0" prefWidth="400.0" styleClass="left-aligned-button" stylesheets="@select-menu.css" text="Sprint" />
                  <Button fx:id="blitzButton" focusTraversable="false" minHeight="100.0" minWidth="500.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleBlitzButton" onMouseEntered="#handleBlitzButtonMouseEnter" onMouseExited="#handleBlitzButtonMouseExit" prefHeight="100.0" prefWidth="400.0" styleClass="left-aligned-button" stylesheets="@select-menu.css" text="Blitz" />
                  <Button fx:id="exitButton" focusTraversable="false" minHeight="100.0" minWidth="500.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleExitButton" onMouseEntered="#handleExitButtonMouseEnter" onMouseExited="#handleExitButtonMouseExit" prefHeight="100.0" prefWidth="400.0" styleClass="left-aligned-button" stylesheets="@select-menu.css" text="Exit" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
