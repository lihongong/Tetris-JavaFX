<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>
      <StackPane>
         <children>
              <Label fx:id="finishLabel" alignment="TOP_CENTER" minHeight="150.0" minWidth="500.0" prefHeight="150.0" prefWidth="500.0" stylesheets="@sprint-over-screen.css" text="Finish" />
            <StackPane fx:id="timePanel" prefHeight="150.0" prefWidth="200.0">
               <children>
                  <Label alignment="TOP_CENTER" minHeight="150.0" minWidth="500.0" prefHeight="150.0" prefWidth="500.0" stylesheets="@sprint-over-screen.css" text="Final Time" translateY="-100.0" />
                  <Label fx:id="finalTimeLabel" alignment="TOP_CENTER" minHeight="150.0" minWidth="500.0" prefHeight="150.0" prefWidth="500.0" stylesheets="@sprint-over-screen.css" text="[finalTime]" translateY="-40.0" />
                  <Label alignment="TOP_CENTER" minHeight="150.0" minWidth="500.0" prefHeight="150.0" prefWidth="500.0" scaleX="0.5" scaleY="0.5" stylesheets="@sprint-over-screen.css" text="Record" translateY="10.0" />
                  <Label fx:id="bestTimeLabel" alignment="TOP_CENTER" minHeight="150.0" minWidth="500.0" prefHeight="150.0" prefWidth="500.0" scaleX="0.5" scaleY="0.5" stylesheets="@sprint-over-screen.css" text="[bestTime]" translateY="40.0" />
               </children>
            </StackPane>
         </children>
      </StackPane>
        <HBox alignment="CENTER_RIGHT">
            <children>
                <VBox maxWidth="1.7976931348623157E308" minWidth="400.0" HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="114.0" spacing="20.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Button fx:id="restartButton" focusTraversable="false" maxWidth="1.7976931348623157E308" minHeight="100.0" minWidth="400.0" mnemonicParsing="false" onAction="#handleRestartButton" onMouseEntered="#handleRestartButtonMouseEnter" onMouseExited="#handleRestartButtonMouseExit" styleClass="left-aligned-button" stylesheets="@global.css" text="Restart" />
                        <Button fx:id="exitButton" focusTraversable="false" maxWidth="1.7976931348623157E308" minHeight="100.0" minWidth="400.0" mnemonicParsing="false" onAction="#handleExitButton" onMouseEntered="#handleExitButtonMouseEnter" onMouseExited="#handleExitButtonMouseExit" styleClass="left-aligned-button" stylesheets="@global.css" text="Exit" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
